<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>DOGGYCO ULTIMATE PRO - V100</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700;900&family=Plus+Jakarta+Sans:wght@700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    
    <style>
        :root { 
            --neon: #00f2ff; --green: #00ff88; --red: #ff3131; --gold: #ffd700; 
            --glass: rgba(255, 255, 255, 0.08); --cat-purple: #bc13fe;
        }
        * { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color: transparent; }
        body { background: #000; font-family: 'Plus Jakarta Sans', sans-serif; color: #fff; display: flex; flex-direction: column; align-items: center; min-height: 100vh; overflow-x: hidden; }
        
        #main-bg { position: fixed; inset: 0; background-image: url('hintergrund.png'); background-size: cover; background-position: center; z-index: -2; background-color: #050505; opacity: 0.6; }
        
        header h1 { font-family: 'Orbitron'; font-size: clamp(30px, 10vw, 60px); color: var(--neon); text-align: center; padding: 30px; letter-spacing: 10px; animation: neonBlink 2s infinite alternate; }
        @keyframes neonBlink { 0%, 100% { text-shadow: 0 0 20px var(--neon), 0 0 40px var(--neon); opacity: 1; } 50% { text-shadow: 0 0 10px var(--neon); opacity: 0.7; } }

        #game-view { width: 100vw; height: 80vh; display: flex; justify-content: center; position: relative; }
        #game-wrap { position:relative; width: 400px; height: 100%; background: rgba(0,0,0,0.5); backdrop-filter: blur(25px); border: 3px solid var(--neon); border-radius: 40px; overflow: hidden; box-shadow: 0 0 50px #000; }

        canvas { position: absolute; inset: 0; z-index: 50; background: transparent; }

        /* HUD */
        #ui-header { position: absolute; top: 20px; width: 100%; z-index: 200; pointer-events: none; padding: 0 25px; }
        #energy-bar-wrap { width: 100%; height: 14px; background: rgba(0,0,0,0.6); border-radius: 10px; border: 1px solid rgba(255,255,255,0.2); overflow: hidden; }
        #energy-fill { height: 100%; width: 100%; background: linear-gradient(90deg, var(--red), var(--gold), var(--green)); transition: width 0.3s linear; }
        #hud-row { display: flex; justify-content: space-between; margin-top: 10px; font-family: 'Orbitron'; font-size: 14px; font-weight: 900; }

        /* OVERLAYS */
        .overlay { position: absolute; inset: 0; display: flex; flex-direction: column; justify-content: center; align-items: center; backdrop-filter: blur(35px); z-index: 1000; background: rgba(0,0,0,0.6); border-radius: 36px; padding: 20px; text-align: center; }
        .main-btn { padding: 16px 40px; background: var(--neon); color: #000; border: none; border-radius: 35px; font-family: 'Orbitron'; font-weight: 900; cursor: pointer; margin: 10px; width: 240px; box-shadow: 0 0 25px var(--neon); }
        #pName { padding: 15px; border-radius: 15px; border: 2px solid var(--neon); background: rgba(255,255,255,0.1); color: #fff; text-align: center; width: 240px; margin-bottom: 20px; font-family: 'Orbitron'; outline: none; }

        /* CONTENT AREA */
        .content-area { width: 100%; max-width: 500px; padding: 40px 20px; }
        .tile { background: var(--glass); backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.1); border-radius: 35px; padding: 25px; text-align: center; margin-bottom: 25px; }
        .btn-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 20px; }
        .icon-btn { padding: 15px; border-radius: 15px; background: rgba(255,255,255,0.05); border: 1px solid var(--neon); color: #fff; text-decoration: none; font-size: 12px; font-weight: bold; display: flex; align-items: center; justify-content: center; gap: 8px; }

        #controls { position: absolute; bottom: 30px; width: 100%; display: flex; justify-content: space-between; padding: 0 45px; z-index: 300; }
        .arrow { width: 75px; height: 75px; background: rgba(255,255,255,0.1); border: 2px solid var(--neon); border-radius: 50%; color: #fff; font-size: 30px; display: flex; align-items: center; justify-content: center; cursor: pointer; }
    </style>
</head>
<body>

<div id="main-bg"></div>
<header><h1>DOGGYCO</h1></header>

<div id="game-view">
    <div id="game-wrap">
        <div id="ui-header">
            <div id="energy-bar-wrap"><div id="energy-fill"></div></div>
            <div id="hud-row">
                <div id="hearts-disp">❤️❤️❤️</div>
                <div id="score-disp">🏆 0</div>
            </div>
        </div>
        
        <canvas id="game-canvas"></canvas>

        <div id="controls">
            <div class="arrow" onmousedown="mLeft()" ontouchstart="mLeft()"><i class="fas fa-chevron-left"></i></div>
            <div class="arrow" onmousedown="mRight()" ontouchstart="mRight()"><i class="fas fa-chevron-right"></i></div>
        </div>

        <div id="start-screen" class="overlay">
            <input type="text" id="pName" placeholder="ENTER NAME" maxlength="12">
            <button class="main-btn" onclick="startGame(false)">PLAY DOGGY</button>
            <button class="main-btn" style="background:var(--cat-purple); box-shadow: 0 0 25px var(--cat-purple);" onclick="startGame(true)">PLAY CAT</button>
        </div>

        <div id="end-screen" class="overlay" style="display:none;">
            <h1 id="f-score" style="color:var(--gold); font-size:50px;">0</h1>
            <button class="main-btn" onclick="location.reload()">RETRY</button>
        </div>
    </div>
</div>

<div class="content-area">
    <div class="tile">
        <h3 style="color:var(--neon); font-family:'Orbitron';"><i class="fas fa-trophy"></i> LEADERBOARD</h3>
        <div id="leaderboard" style="margin-top:15px; font-size:14px;">Ranking Loading...</div>
    </div>
    
    <div class="tile">
        <h3 style="color:var(--gold); font-family:'Orbitron';"><i class="fas fa-heart"></i> SUPPORT</h3>
        <div class="btn-grid">
            <a href="https://www.tiktok.com" class="icon-btn"><i class="fab fa-tiktok"></i> TikTok</a>
            <a href="https://www.paypal.me" class="icon-btn"><i class="fab fa-paypal"></i> PayPal</a>
            <a href="#" class="icon-btn" onclick="copyWallet()"><i class="fas fa-wallet"></i> Copy BTC</a>
            <a href="#" class="icon-btn" onclick="alert('Food: +10-50pts | Avoid Spiders!')"><i class="fas fa-info"></i> Rules</a>
        </div>
    </div>
</div>

<audio id="bgMusic" loop src="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3"></audio>

<script>
// --- CONFIG ---
const SUPABASE_URL = 'https://ovmsstdroxkinisqwlhw.supabase.co';
const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im92bXNzdGRyb3hraW5pc3F3bGh3Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzIyMzM3OTEsImV4cCI6MjA4NzgwOTc5MX0.SOsi-Aeb_wSp40_TTymaiiU0Kn_3rhG_LnvLjJP66z8';
let supabase = null;

const canvas = document.getElementById("game-canvas");
const ctx = canvas.getContext("2d");
const W = 400;
let H, active = false, isCat = false, score = 0, energy = 100, hearts = 3, lane = 2, dogX = 200, targetX = 200;
let items = [], spiders = [], floaters = [], lastTime = 0;

// --- INITIALIZATION ---
function init() {
    canvas.width = W;
    const gameWrap = document.getElementById("game-wrap");
    H = canvas.height = gameWrap.offsetHeight;
    
    // Verbindung zu Supabase herstellen
    if (typeof supabasejs !== 'undefined' || window.supabase) {
        supabase = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);
        loadRanks();
    } else {
        document.getElementById("leaderboard").innerText = "Database Offline";
    }
}

// --- GAME FUNCTIONS ---
function startGame(cat) {
    const name = document.getElementById("pName").value;
    if(!name || name.trim() === "") { alert("Please enter a name!"); return; }
    isCat = cat;
    document.getElementById("start-screen").style.display = "none";
    document.getElementById("bgMusic").play().catch(() => {});
    active = true; 
    lastTime = performance.now();
    requestAnimationFrame(loop);
}

function mLeft() { if(active && lane > 0) { lane--; targetX = lane * 80 + 40; } }
function mRight() { if(active && lane < 4) { lane++; targetX = lane * 80 + 40; } }

// --- GAME LOOP ---
function loop(t) {
    if(!active) return;
    let dt = (t - lastTime) / 1000; lastTime = t;
    if(dt > 0.1) dt = 0.016;
    ctx.clearRect(0,0,W,H);

    energy -= 6.5 * dt;
    document.getElementById("energy-fill").style.width = Math.max(0, energy) + "%";
    document.getElementById("score-disp").innerText = "🏆 " + Math.floor(score);
    document.getElementById("hearts-disp").innerText = "❤️".repeat(Math.max(0, hearts));

    if(energy <= 0 || hearts <= 0) {
        active = false; 
        document.getElementById("end-screen").style.display = "flex";
        document.getElementById("f-score").innerText = "SCORE: " + Math.floor(score);
        saveScore(); 
        return;
    }

    // Spawning logic
    if(Math.random() < 0.035) {
        let ln = Math.floor(Math.random()*5);
        if(Math.random() < 0.75) {
            let r = Math.random();
            let type = r < 0.1 ? '👮' : (r < 0.7 ? (isCat?'🍼':'🦴') : (r < 0.9 ? '🍪' : '🥩'));
            items.push({lane: ln, y: -50, type, p: (type==='🦴'||type==='🍼'?10:(type==='🍪'?25:50))});
        } else if(spiders.length < 2) {
            spiders.push({lane: ln, y: 0, d: 1, speed: 190});
        }
    }

    // Spiders logic
    spiders.forEach((s, i) => {
        s.y += s.speed * dt * s.d;
        if(s.y > H * 0.7) s.d = -1;
        if(s.y < -50) spiders.splice(i, 1);
        let sx = s.lane * 80 + 40;
        ctx.strokeStyle = "rgba(255,255,255,0.4)"; ctx.lineWidth = 2;
        ctx.beginPath(); ctx.moveTo(sx, 0); ctx.lineTo(sx, s.y); ctx.stroke();
        ctx.font = "32px Arial"; ctx.textAlign = "center";
        ctx.fillText(isCat?"🐍":"🕷️", sx, s.y+20);
        if(s.lane === lane && s.y > H-150 && s.y < H-80) { energy -= 25; spiders.splice(i,1); }
    });

    // Items logic
    items.forEach((it, i) => {
        it.y += (240 + score/12) * dt;
        let ix = it.lane * 80 + 40;
        ctx.font = "38px Arial"; ctx.textAlign = "center";
        ctx.fillText(it.type, ix, it.y);
        if(it.lane === lane && it.y > H-150 && it.y < H-80) {
            if(it.type === '👮') { hearts--; floaters.push({x:ix, y:it.y, txt:"-❤️", c:"red"}); }
            else { score += it.p; energy = Math.min(100, energy + 12); floaters.push({x:ix, y:it.y, txt:"+"+it.p, c:"#00ff88"}); }
            items.splice(i, 1);
        }
        if(it.y > H) items.splice(i, 1);
    });

    // Player
    dogX += (targetX - dogX) * 0.22;
    ctx.font = "75px Arial"; ctx.textAlign = "center";
    ctx.fillText(isCat ? "🐱" : "🐶", dogX, H-100);

    // Animations
    floaters.forEach((f, i) => {
        f.y -= 3; f.x += 1.5; 
        ctx.fillStyle = f.c; ctx.font = "bold 22px Orbitron"; ctx.fillText(f.txt, f.x, f.y);
        if(f.y < 0) floaters.splice(i, 1);
    });

    requestAnimationFrame(loop);
}

// --- DATABASE HANDLERS (REPAIRED) ---

async function saveScore() {
    const n = document.getElementById("pName").value;
    const finalScore = Math.floor(score);
    if(!supabase || !n) return;

    try {
        const { error } = await supabase
            .from('leaderboard')
            .insert([{ n: n, s: finalScore }]);
        if(error) throw error;
        loadRanks(); 
    } catch(e) { console.error("Save Error:", e.message); }
}

async function loadRanks() {
    if(!supabase) return;
    try {
        const { data, error } = await supabase
            .from('leaderboard')
            .select('n, s')
            .order('s', { ascending: false })
            .limit(5);

        if(error) throw error;
        
        const lb = document.getElementById("leaderboard");
        if(data && data.length > 0) {
            lb.innerHTML = data.map((r, i) => `
                <div style="display:flex; justify-content:space-between; padding:8px 5px; border-bottom:1px solid rgba(255,255,255,0.1)">
                    <span style="color:var(--neon)">${i+1}. ${r.n}</span>
                    <span style="color:var(--gold); font-family:'Orbitron'">${r.s}</span>
                </div>
            `).join('');
        } else {
            lb.innerText = "No scores yet!";
        }
    } catch(e) { 
        console.error("Load Error:", e.message);
        document.getElementById("leaderboard").innerText = "Local Mode Active"; 
    }
}

function copyWallet() { 
    navigator.clipboard.writeText('bc1qkm22c6w896u9n9cxp8ld049maef4xs5xn060ed'); 
    alert("BTC Address Copied!"); 
}

window.onload = init;
</script>
</body>
</html>
